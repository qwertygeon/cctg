#compdef cctg
# zsh 자동완성 — cctg
# 설치: install.sh 가 fpath 디렉터리(~/.local/share/zsh/site-functions/_cctg)로 복사한다.

_cctg() {
  local -a cmds
  # lib/channels.sh IMPLEMENTED_CHANNELS 미러 — 채널 추가 시 함께 갱신(완성 파일은 lib 를 source 안 함).
  local CCTG_COMPLETION_CHANNELS="telegram discord"
  cmds=(
    'add:프로젝트 봇 등록'
    'rm:등록 해제'
    'rename:이름 변경'
    'config:봇별 옵션 보기·수정'
    'common:공통 권한 정책 보기·수정'
    'up:기동'
    'down:정지'
    'restart:재기동'
    'status:등록/실행 상태'
    'logs:최근 로그 출력'
    'attach:tmux 세션 attach'
    'lang:CLI 출력 언어 보기·변경'
    'doctor:환경 진단'
    'update:git pull 후 재설치'
    'version:버전 출력'
    'help:도움말'
  )

  _cctg_names() {
    local reg="${CC_TG_REGISTRY:-${CC_CHANNELS_DIR:-$HOME/.claude/channels}/projects.conf}"
    local -a names
    names=(${(f)"$(awk -F'|' '/^[[:space:]]*#/{next}/^[[:space:]]*$/{next}{gsub(/^[ \t]+|[ \t]+$/,"",$1);print $1}' "$reg" 2>/dev/null)"})
    _describe -t bots '봇' names
  }

  if (( CURRENT == 2 )); then
    _describe -t commands '명령' cmds
    return
  fi

  case "${words[2]}" in
    rm)
      (( CURRENT == 3 )) && _cctg_names
      (( CURRENT >= 4 )) && compadd -- --purge --help ;;
    logs|attach)
      (( CURRENT == 3 )) && _cctg_names
      (( CURRENT == 3 )) || compadd -- --help ;;
    rename)
      # 3번째 인자(old)만 보완. 4번째(new name)는 자유 입력. 5번째 이후 --keep-dir.
      (( CURRENT == 3 )) && _cctg_names
      (( CURRENT >= 5 )) && compadd -- --keep-dir --help ;;
    up|down|restart)
      # 다중 타겟: 모든 인자 위치에서 이름·all·--help 보완
      if (( CURRENT >= 3 )); then
        compadd -- all --help
        _cctg_names
      fi ;;
    config)
      # config <name> <action> — 3번째=봇명, 4번째=동작, 5번째=값(mode/cwd/token 별 보완)
      if (( CURRENT == 3 )); then
        _cctg_names
      elif (( CURRENT == 4 )); then
        compadd -- show edit mode args snapshot width cwd token --help
      elif (( CURRENT == 5 )); then
        case "${words[4]}" in
          mode) compadd -- acceptEdits auto bypassPermissions default dontAsk plan clear ;;
          width) compadd -- clear default ;;
          cwd)  _files -/ ;;
          token) compadd -- --token-env --token-stdin --help ;;
        esac
      fi ;;
    common)
      # common <action> [...]
      if (( CURRENT == 3 )); then
        compadd -- show edit mode width deny allow --help
      elif (( CURRENT == 4 )); then
        case "${words[3]}" in
          deny|allow) compadd -- add rm ;;
          mode) compadd -- acceptEdits auto bypassPermissions default dontAsk plan ;;
          width) compadd -- clear default ;;
        esac
      fi ;;
    add)
      # add <name> <cwd> [--id <num>] [--token-env <VAR>|--token-stdin] [--mode <m>] [--channel <name>] [--group <id>[:nomention][:allow=m1,m2]]
      if (( CURRENT == 4 )); then
        _files -/
      elif (( CURRENT >= 5 )); then
        case "${words[CURRENT-1]}" in
          --mode)      compadd -- acceptEdits auto bypassPermissions default dontAsk plan ;;
          --token-env) compadd -- ${(k)parameters} ;;
          --channel)   compadd -- ${=CCTG_COMPLETION_CHANNELS} ;;
          --id)        ;; # 자유 입력(숫자)
          --group)     ;; # 자유 입력(컴파운드 토큰 <id>[:nomention][:allow=...])
          *)           compadd -- --id --token-env --token-stdin --mode --channel --group --help ;;
        esac
      fi ;;
    status)
      (( CURRENT == 3 )) && compadd -- --json -a --all --help ;;
    lang)
      (( CURRENT == 3 )) && compadd -- show en ko clear --help ;;
    update)
      compadd -- --version --latest --list --alias --no-alias --help ;;
  esac
}

_cctg "$@"
