#compdef cctg
# zsh 자동완성 — cctg
# 설치: install.sh 가 fpath 디렉터리(~/.local/share/zsh/site-functions/_cctg)로 복사한다.

_cctg() {
  local -a cmds
  cmds=(
    'add:프로젝트 봇 등록'
    'rm:등록 해제'
    'rename:이름 변경'
    'config:봇별 옵션 보기·수정'
    'common:공통 권한 정책 보기·수정'
    'up:기동'
    'down:정지'
    'restart:재기동'
    'status:등록/실행 상태'
    'logs:최근 로그 출력'
    'attach:tmux 세션 attach'
    'lang:CLI 출력 언어 보기·변경'
    'doctor:환경 진단'
    'update:git pull 후 재설치'
    'version:버전 출력'
    'help:도움말'
  )

  _cctg_names() {
    local reg="${CC_TG_REGISTRY:-${CC_CHANNELS_DIR:-$HOME/.claude/channels}/projects.conf}"
    local -a names
    names=(${(f)"$(awk -F'|' '/^[[:space:]]*#/{next}/^[[:space:]]*$/{next}{gsub(/^[ \t]+|[ \t]+$/,"",$1);print $1}' "$reg" 2>/dev/null)"})
    _describe -t bots '봇' names
  }

  if (( CURRENT == 2 )); then
    _describe -t commands '명령' cmds
    return
  fi

  case "${words[2]}" in
    rm)
      (( CURRENT == 3 )) && _cctg_names
      (( CURRENT >= 4 )) && compadd -- --purge ;;
    logs|attach)
      (( CURRENT == 3 )) && _cctg_names ;;
    rename)
      # 3번째 인자(old)만 보완. 4번째(new name)는 자유 입력. 5번째 이후 --keep-dir.
      (( CURRENT == 3 )) && _cctg_names
      (( CURRENT >= 5 )) && compadd -- --keep-dir ;;
    up|down|restart)
      if (( CURRENT == 3 )); then
        compadd -- all
        _cctg_names
      fi ;;
    config)
      # config <name> <action> — 3번째=봇명, 4번째=동작
      if (( CURRENT == 3 )); then
        _cctg_names
      elif (( CURRENT == 4 )); then
        compadd -- show edit mode args snapshot
      fi ;;
    common)
      # common <action> [...]
      if (( CURRENT == 3 )); then
        compadd -- show edit mode deny allow
      elif (( CURRENT == 4 )); then
        case "${words[3]}" in
          deny|allow) compadd -- add rm ;;
          mode) compadd -- acceptEdits auto bypassPermissions default dontAsk plan ;;
        esac
      fi ;;
    add)
      # add <name> <cwd> [--id <num>] [--token-env <VAR>|--token-stdin] [--mode <m>] [--channel <name>]
      if (( CURRENT == 4 )); then
        _files -/
      elif (( CURRENT >= 5 )); then
        case "${words[CURRENT-1]}" in
          --mode)      compadd -- acceptEdits auto bypassPermissions default dontAsk plan ;;
          --token-env) compadd -- ${(k)parameters} ;;
          --channel)   compadd -- telegram ;;
          --id)        ;; # 자유 입력(숫자)
          *)           compadd -- --id --token-env --token-stdin --mode --channel ;;
        esac
      fi ;;
    status)
      (( CURRENT == 3 )) && compadd -- --json ;;
    lang)
      (( CURRENT == 3 )) && compadd -- show en ko clear ;;
  esac
}

_cctg "$@"
