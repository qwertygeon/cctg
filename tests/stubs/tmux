#!/usr/bin/env bash
# Fake tmux for the cctg test suite.
#
# Deterministic and side-effect-free: it never talks to a real tmux server, so
# tests can exercise is_running / status / up / down / restart without spawning
# real sessions.
#
# Session state is tracked in the file named by $FAKE_TMUX_STATE (one session
# name per line); the test harness points it inside $BATS_TEST_TMPDIR. When
# $FAKE_TMUX_STATE is unset the stub is stateless and reports nothing running.
#   - new-session  -> records the -s <name> session as running
#   - kill-session -> removes the session the -t <target> resolves to
#   - has-session  -> exit 0 if the -t <target> resolves to a session, else 1
#   - display-message -> prints $FAKE_TMUX_CREATED (default 1700000000)
#   - capture-pane -> prints two fixed lines (clean rendered text)
#
# Target ('-t') resolution mirrors real tmux so prefix-collision bugs surface:
#   - '=<name>'  -> EXACT match only (tmux exact-match prefix)
#   - '<name>'   -> exact match if present, else PREFIX match (real tmux falls
#                   back to prefix when no exact session exists). cctg must pass
#                   '=' targets for lookups; a plain target that prefix-matches a
#                   longer session is the very bug the regression test guards.

state="${FAKE_TMUX_STATE:-}"
cmd="${1:-}"; shift || true

# Pull a flag's value out of the remaining args (e.g. -s <val> / -t <val>).
flag_val() {
  local want="$1"; shift
  while [ $# -gt 0 ]; do
    [ "$1" = "$want" ] && { printf '%s' "${2:-}"; return 0; }
    shift
  done
  return 1
}

# Print every recorded session the target resolves to (one per line).
# Models tmux: '=name' exact; plain name exact-then-prefix.
resolve() {
  local target="$1"
  [ -n "$state" ] && [ -f "$state" ] || return 0
  case "$target" in
    "="*)
      local exact="${target#=}"
      grep -qxF "$exact" "$state" && printf '%s\n' "$exact" ;;
    *)
      if grep -qxF "$target" "$state"; then
        printf '%s\n' "$target"
      else
        awk -v t="$target" 'index($0,t)==1 {print}' "$state"
      fi ;;
  esac
}

# Resolve a target-PANE (capture-pane / display-message). Mirrors the real tmux
# quirk surfaced in production: the '=' exact-match prefix is only valid for a
# target-SESSION. As a target-pane, a bare '=NAME' (no ':' window/pane part) is
# NOT resolvable — real tmux errors "can't find pane" (capture-pane) or yields an
# empty value (display-message). It must carry a ':' (e.g. '=NAME:') to resolve.
# A plain (no '=') target still resolves via exact-then-prefix on the session.
# Without this distinction the stub accepts both forms and the regression that
# passes a bare '=NAME' to a pane command slips through the suite.
resolve_pane() {
  local target="$1"
  case "$target" in
    "="*) case "$target" in *:*) ;; *) return 1 ;; esac ;;
  esac
  resolve "${target%%:*}"
}

case "$cmd" in
  has-session)
    target="$(flag_val -t "$@")" || exit 1
    [ -n "$(resolve "$target")" ] && exit 0
    exit 1 ;;
  new-session)
    # Fault injection: a non-empty FAKE_TMUX_FAIL_NEWSESSION makes new-session fail
    # (models tmux server-unavailable / resource exhaustion) so cctg's up-failure
    # guard can be exercised. Nothing is recorded as running.
    [ -n "${FAKE_TMUX_FAIL_NEWSESSION:-}" ] && exit 1
    name="$(flag_val -s "$@")" || exit 0
    if [ -n "$state" ]; then
      grep -qxF "$name" "$state" 2>/dev/null || printf '%s\n' "$name" >> "$state"
    fi
    # Capture the full new-session command for SC-025 cwd verification.
    # Tests that need to inspect the launch string set FAKE_TMUX_LASTCMD to a
    # writable file path; the stub writes the raw argument list there (one arg
    # per line) so tests can grep for the expected `cd <path>` fragment.
    if [ -n "${FAKE_TMUX_LASTCMD:-}" ]; then
      printf '%s\n' "$@" > "$FAKE_TMUX_LASTCMD"
    fi ;;
  kill-session)
    # Fault injection: FAKE_TMUX_FAIL_KILL makes kill-session fail (the session is
    # left as running) so cctg's down-failure guard can be exercised.
    [ -n "${FAKE_TMUX_FAIL_KILL:-}" ] && exit 1
    target="$(flag_val -t "$@")" || exit 0
    if [ -n "$state" ] && [ -f "$state" ]; then
      # Remove exactly the session(s) the target resolves to (faithful to tmux:
      # a plain prefix target removes the prefix-matched session, not the literal).
      matched="$(resolve "$target")"
      if [ -n "$matched" ]; then
        grep -vxF -f <(printf '%s\n' "$matched") "$state" > "$state.tmp" 2>/dev/null || : > "$state.tmp"
        mv "$state.tmp" "$state"
      fi
    fi ;;
  display-message)
    # target-pane: a bare '=NAME' resolves to nothing -> empty value, rc 0
    # (faithful to real tmux; this is the silent status/uptime bug's signature).
    target="$(flag_val -t "$@")" || true
    resolved="$(resolve_pane "$target")"
    if [ -n "$target" ] && [ -z "$resolved" ]; then exit 0; fi
    # Format-aware: '#{pane_pid}' (liveness check) returns FAKE_TMUX_PANE_PID so a test
    # can point claude_alive's process walk at a tree it controls. '#{session_created}'
    # is per-session when FAKE_TMUX_CREATED_FILE (lines "<session>\t<epoch>") maps the
    # resolved session — mirroring real tmux returning each session's own creation time,
    # so the status recency-sort can be exercised. Everything else (and any unmapped
    # session, e.g. pane_current_path) falls back to FAKE_TMUX_CREATED as before.
    fmt=""; for fmt in "$@"; do :; done
    case "$fmt" in
      *pane_pid*) printf '%s\n' "${FAKE_TMUX_PANE_PID:-0}" ;;
      # last-activity (status #{window_activity}); tests can pin FAKE_TMUX_ACTIVITY.
      *window_activity*) printf '%s\n' "${FAKE_TMUX_ACTIVITY:-${FAKE_TMUX_CREATED:-1700000000}}" ;;
      *session_created*)
        created=""
        if [ -n "${FAKE_TMUX_CREATED_FILE:-}" ] && [ -f "${FAKE_TMUX_CREATED_FILE}" ] && [ -n "$resolved" ]; then
          created="$(awk -F'\t' -v s="$resolved" '$1==s{print $2; exit}' "$FAKE_TMUX_CREATED_FILE")"
        fi
        [ -n "$created" ] || created="${FAKE_TMUX_CREATED:-1700000000}"
        printf '%s\n' "$created" ;;
      *)          printf '%s\n' "${FAKE_TMUX_CREATED:-1700000000}" ;;
    esac ;;
  capture-pane)
    # target-pane: a bare '=NAME' can't be resolved -> "can't find pane", rc 1.
    target="$(flag_val -t "$@")" || { printf "no target\n" >&2; exit 1; }
    if [ -z "$(resolve_pane "$target")" ]; then
      printf "can't find pane: %s\n" "$target" >&2; exit 1
    fi
    printf 'fake pane line 1\nfake pane line 2\n' ;;
  attach|send-keys)
    : ;;
  *)
    : ;;
esac
exit 0
