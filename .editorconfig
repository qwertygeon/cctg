# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Shell scripts and completions use 2-space indentation (Bash 3.2 compatible).
[*.{sh,bash}]
indent_style = space
indent_size = 2

[_cctg]
indent_style = space
indent_size = 2

# Markdown: trailing whitespace can be a hard line break, so don't trim.
[*.md]
trim_trailing_whitespace = false
